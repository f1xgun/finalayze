# Finalayze Environment Configuration
# Copy to .env and fill in real values

# Work mode: debug | sandbox | test | real
FINALAYZE_MODE=debug

# Base currency for portfolio aggregation
FINALAYZE_BASE_CURRENCY=USD

# Database
FINALAYZE_DATABASE_URL=postgresql+asyncpg://finalayze:secret@localhost:5432/finalayze

# Redis
FINALAYZE_REDIS_URL=redis://localhost:6379/0

# ── API Keys ──────────────────────────────────
# Finnhub (US market data + news)
FINALAYZE_FINNHUB_API_KEY=

# NewsAPI (global news)
FINALAYZE_NEWSAPI_API_KEY=

# Anthropic (Claude LLM)
FINALAYZE_ANTHROPIC_API_KEY=

# ── Alpaca (US Broker) ────────────────────────
FINALAYZE_ALPACA_API_KEY=
FINALAYZE_ALPACA_SECRET_KEY=
FINALAYZE_ALPACA_PAPER=true

# ── Tinkoff Invest (MOEX Broker) ─────────────
FINALAYZE_TINKOFF_TOKEN=
FINALAYZE_TINKOFF_SANDBOX=true

# ── Per-market trading limits ─────────────────
FINALAYZE_ALPACA_MAX_PORTFOLIO_VALUE=10000
FINALAYZE_TINKOFF_MAX_PORTFOLIO_VALUE=500000

# ── Global risk parameters ────────────────────
FINALAYZE_MAX_POSITIONS_PER_MARKET=10
FINALAYZE_MAX_POSITION_PCT=0.20
FINALAYZE_DAILY_LOSS_LIMIT_PCT=0.02
FINALAYZE_MAX_CROSS_MARKET_EXPOSURE_PCT=0.80

# ── Risk parameters ──────────────────────────
FINALAYZE_KELLY_FRACTION=0.5
FINALAYZE_STOP_LOSS_ATR_MULTIPLIER=2.0
FINALAYZE_CIRCUIT_BREAKER_L1=0.05
FINALAYZE_CIRCUIT_BREAKER_L2=0.10
FINALAYZE_CIRCUIT_BREAKER_L3=0.15

# ── LLM ──────────────────────────────────────
FINALAYZE_LLM_MODEL=claude-sonnet-4-20250514

# ── Safety (Real mode) ──────────────────────
FINALAYZE_REAL_CONFIRMED=false
FINALAYZE_API_KEY=                        # REQUIRED: set a strong random value
FINALAYZE_REAL_TOKEN=

# ── Cycle intervals ───────────────────────────
FINALAYZE_NEWS_CYCLE_MINUTES=30
FINALAYZE_STRATEGY_CYCLE_MINUTES=60
FINALAYZE_DAILY_RESET_HOUR_UTC=0

# ── Telegram alerting ─────────────────────────
FINALAYZE_TELEGRAM_BOT_TOKEN=
FINALAYZE_TELEGRAM_CHAT_ID=
